{% if allowed_senders is defined and allowed_senders %}
allowed_senders:
{% for sender in allowed_senders %}
  - {{ sender }}
{% endfor %}

{% endif %}
events:
{% for event in events %}
  {{ event.name }}:
{% if event.name == "push" %}
    branches:
{% for branch, handler in event.branches.items() %}
      {{ branch }}: {{ handler }}
{% endfor %}
{% else %}
{% for action, handler in event.actions.items() %}
    {{ action }}: {{ handler }}
{% endfor %}
{% endif %}
{% endfor %}
